# Algoverse SageMaker environment
# Copy to ~/.sagemaker.env, fill in values, then: source ~/.sagemaker.env

AWS_REGION=us-east-2
S3_BUCKET=algoverse-yourhandle-12345678-us-east-2
SM_ROLE_ARN=arn:aws:iam::123456789012:role/AmazonSageMaker-yourhandle
STUDENT_HANDLE=yourhandle
INSTANCE_TYPE=ml.g6.xlarge
PROJECT_SLUG=my-project
HF_TOKEN=hf_xxxx                     # optional — leave blank if not needed
WANDB_API_KEY=                        # optional
